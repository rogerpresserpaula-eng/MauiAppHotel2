<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel2.Views.HospedagemContratada"
             NavigationPage.HasNavigationBar="False"
             Background="{StaticResource Background}">

    <VerticalStackLayout VerticalOptions="CenterAndExpand"
                         HorizontalOptions="Center">

        <Label Text="Suíte Super Luxo"
               TextColor="{StaticResource DarkGreen}"
               FontFamily="Cause"
               FontSize="50"
               HorizontalTextAlignment="Center"/>

        <!--Quantidade de pessoas-->
        <Frame Margin="10">
            <HorizontalStackLayout> <!--Adultos-->
                <Label Text="Adultos: " />
                <Label Text="2" 
                       TextColor="{StaticResource DarkGreen}" />
                
                <HorizontalStackLayout> <!--Crianças-->
                    <Label Text="Crianças: " />
                    <Label Text="1" 
                           TextColor="{StaticResource DarkGreen}" />
                </HorizontalStackLayout>
                
            </HorizontalStackLayout>
        </Frame>

        <!--Informações-->
        <Frame Margin="10">
            <Grid ColumnDefinitions="*, *, *"
                  RowDefinitions="Auto, Auto">

                <Label Grid.Row="0" Grid.Column="0" Text="Check-in" />
                <Label Grid.Row="0" Grid.Column="1" Text="Check-out" />
                <Label Grid.Row="0" Grid.Column="2" Text="Estádia" />

                <Label Grid.Row="1" Grid.Column="0" Text="27/05/2024" />
                <Label Grid.Row="1" Grid.Column="1" Text="30/05/2024" />
                <Label Grid.Row="1" Grid.Column="2" Text="3" />

            </Grid>
        </Frame>
       
        <!--Valor Total-->
        <Frame Margin="10">
            <HorizontalStackLayout>

                <Label Text="Valor Total: "/>
                <Label Text=" R$750,00:"/>
                

            </HorizontalStackLayout>
        </Frame>
        
        <!--Botão Voltar-->
        <Button Text="Voltar" 
                HorizontalOptions="Center"
                Clicked="Button_Clicked"/>


    </VerticalStackLayout>
</ContentPage>